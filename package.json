{
  "name": "dean-chat",
  "version": "1.0.0",
  "description": "Dean Chat game overlay",
  "author": "Niko",
  "main": "app/main/main.js",
  "scripts": {
    "start": "electron .",
    "watch:css": "tailwindcss -i ./app/styles/input.css -o ./dist/output.css --watch",
    "build:css": "tailwindcss -i ./app/styles/input.css -o ./dist/output.css",
    "pack": "npm run build:css && electron-builder --dir",
    "dist": "npm run build:css && electron-builder"
  },
  "build": {
    "appId": "com.dean.chat",
    "productName": "Dean Chat",
    "forceCodeSigning": false,
    "mac": {
      "identity": null
    },
    "win": {
      "target": "portable",
      "icon": "app/assets/icon.png"
    },
    "files": [
      "app/**/*",
      "dist/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "lucide": "^1.8.0"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^3.4.0"
  }
}
